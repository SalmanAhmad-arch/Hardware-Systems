<div class="wishlist-page">
  <h1>Your Wishlist</h1>

  <div id="wishlistGrid" class="wishlist-grid"></div>

  <p id="emptyMsg" style="display:none;">Your wishlist is empty.</p>
</div>
{% stylesheet %}
  .wishlist-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 20px;
}

.wishlist-card {
  border: 1px solid #eee;
  padding: 15px;
  text-align: center;
}

.wishlist-card img {
  width: 100%;
  height: 200px;
  object-fit: cover;
}
{% endstylesheet %}