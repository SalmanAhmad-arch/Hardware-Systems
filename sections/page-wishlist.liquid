<div id="wishlist-container" class="cards-grid-ss"></div>
<div id="wishlist-container" class="cards-grid-ss"></div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('wishlist-container');
  
  // 🟢 FUNCTION: Render karo
  function renderWishlist() {
    let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];

    if (!wishlist.length) {
      container.innerHTML = "<p>Your wishlist is empty.</p>";
      return;
    }

    // 🟢 HTML generate karo (innerHTML += mat use karo - slow aur buggy)
    container.innerHTML = wishlist.map(product => `
      <div class="system-card-ss" data-product-id="${product.id}">
        <div class="card-image-wrapper">
          <img src="${product.image || 'https://via.placeholder.com/300'}" 
               alt="${product.title}" 
               class="card-image-ss"/>
        </div>
        <div class="card-content-ss">
          <h3 class="card-title-ss">${product.title}</h3>
          <p class="card-description-ss">${product.description || ''}</p>
          
          <!-- 🟢 Button mein type="button" add karo (form submit na ho) -->
          <button type="button" class="wishlist-btn active" data-handle="${product.handle}">
            <i class="fa-solid fa-heart"></i> Remove
          </button>
          
          <a href="${product.url}" class="view-system-ss">View System</a>
        </div>
      </div>
    `).join('');
  }

  // 🟢 EVENT DELEGATION - Proper tarike se
  container.addEventListener('click', function(e) {
    // Button ya uske andar ka icon dono ko handle karo
    const btn = e.target.closest('.wishlist-btn');
    if (!btn) return; // Button pe click nahi hua to exit

    e.preventDefault(); // 🟢 Default action roko
    e.stopPropagation(); // 🟢 Event bubble roko

    const handle = btn.dataset.handle;
    console.log('Removing:', handle); // Debug ke liye

    // 🟢 LocalStorage se remove karo
    let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];
    wishlist = wishlist.filter(p => p.handle !== handle);
    localStorage.setItem('wishlist', JSON.stringify(wishlist));

    // 🟢 Re-render karo (reliable hai)
    renderWishlist();
  });

  // Pehli baar render karo
  renderWishlist();
});
</script>