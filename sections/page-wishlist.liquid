<style>
/* 🎯 GRID CONTAINER */
.cards-grid-ss {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 25px;
  padding: 40px 20px;
  max-width: 1400px;
  margin: 0 auto;
}

/* 🎯 INDIVIDUAL CARD */
.system-card-ss {
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 4px 15px rgba(0,0,0,0.08);
  transition: all 0.3s ease;
  position: relative;
}

.system-card-ss:hover {
  transform: translateY(-8px);
  box-shadow: 0 12px 30px rgba(0,0,0,0.15);
}

/* 🎯 IMAGE WRAPPER */
.card-image-wrapper {
  position: relative;
  width: 100%;
  height: 280px;
  overflow: hidden;
  background: #f5f5f5;
}

.card-image-ss {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.4s ease;
}

.system-card-ss:hover .card-image-ss {
  transform: scale(1.05);
}

/* 🎯 CARD CONTENT */
.card-content-ss {
  padding: 20px;
  position: relative;
}

.card-title-ss {
  font-size: 18px;
  font-weight: 600;
  color: #1a1a1a;
  margin: 0 0 10px 0;
  line-height: 1.3;
}

.card-description-ss {
  font-size: 14px;
  color: #666;
  line-height: 1.5;
  margin: 0 0 20px 0;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  overflow: hidden;
}

/* 🎯 WISHLIST BUTTON (Heart) */
.wishlist-btn {
  position: absolute;
  top: 20px;
  right: 20px;
  width: 40px;
  height: 40px;
  border-radius: 50%;
  border: none;
  background: #fff;
  cursor: pointer;
  display: flex;
  align-items: center;
  justify-content: center;
  box-shadow: 0 2px 8px rgba(0,0,0,0.1);
  transition: all 0.3s ease;
  z-index: 10;
}

.wishlist-btn:hover {
  transform: scale(1.1);
  background: #ff4444;
  color: #fff;
}

.wishlist-btn.active {
  background: #ff4444;
  color: #fff;
}

.wishlist-btn i {
  font-size: 16px;
}

/* 🎯 VIEW BUTTON */
.view-system-ss {
  display: inline-block;
  padding: 12px 24px;
  background: #1a1a1a;
  color: #fff;
  text-decoration: none;
  border-radius: 6px;
  font-size: 13px;
  font-weight: 500;
  letter-spacing: 0.5px;
  transition: all 0.3s ease;
  width: 100%;
  text-align: center;
  box-sizing: border-box;
}

.view-system-ss:hover {
  background: #333;
  transform: translateY(-2px);
}

/* 🎯 EMPTY STATE */
.empty-wishlist {
  text-align: center;
  padding: 80px 20px;
  color: #666;
  font-size: 18px;
  grid-column: 1 / -1;
}

.empty-wishlist i {
  font-size: 64px;
  color: #ddd;
  margin-bottom: 20px;
  display: block;
}

/* 🎯 RESPONSIVE */
@media (max-width: 1024px) {
  .cards-grid-ss {
    grid-template-columns: repeat(2, 1fr);
    gap: 20px;
  }
}

@media (max-width: 600px) {
  .cards-grid-ss {
    grid-template-columns: 1fr;
    gap: 15px;
    padding: 20px 15px;
  }
  
  .card-image-wrapper {
    height: 220px;
  }
}
</style>

<!-- Font Awesome CDN -->
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">

<div id="wishlist-container" class="cards-grid-ss"></div>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const container = document.getElementById('wishlist-container');

  function renderWishlist() {
    let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];
    
    // Clean corrupted data
    wishlist = wishlist.filter(p => p && p.id && p.handle);

    if (!wishlist.length) {
      container.innerHTML = `
        <div class="empty-wishlist">
          <i class="fa-regular fa-heart"></i>
          <p>Your wishlist is empty.</p>
          <a href="/collections/all" style="color: #1a1a1a; text-decoration: underline;">Continue Shopping</a>
        </div>
      `;
      return;
    }

    container.innerHTML = wishlist.map(product => `
      <div class="system-card-ss" data-product-id="${product.id}">
        <div class="card-image-wrapper">
          <img src="${product.image || 'https://via.placeholder.com/400x300?text=No+Image'}" 
               alt="${product.title || 'Product'}" 
               class="card-image-ss"
               onerror="this.src='https://via.placeholder.com/400x300?text=No+Image'"/>
          
          <button type="button" class="wishlist-btn active" data-handle="${product.handle}" title="Remove from wishlist">
            <i class="fa-solid fa-heart"></i>
          </button>
        </div>
        
        <div class="card-content-ss">
          <h3 class="card-title-ss">${product.title || 'Untitled Product'}</h3>
          <p class="card-description-ss">${product.description || 'No description available'}</p>
          <a href="${product.url || '#'}" class="view-system-ss">View System</a>
        </div>
      </div>
    `).join('');
  }

  // Remove handler
  container.addEventListener('click', function(e) {
    const btn = e.target.closest('.wishlist-btn');
    if (!btn) return;

    e.preventDefault();
    e.stopPropagation();

    const handleToRemove = btn.dataset.handle;
    
    let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];
    wishlist = wishlist.filter(p => p && p.handle && p.handle !== handleToRemove);
    
    localStorage.setItem('wishlist', JSON.stringify(wishlist));
    renderWishlist();
  });

  renderWishlist();
});
</script>