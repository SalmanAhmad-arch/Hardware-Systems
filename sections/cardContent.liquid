<style>
    .systems-section {
        font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
        max-width: 1400px;
        margin: 0 auto;
        padding: 60px 20px;
        background: #f8f9fa;
    }

    .systems-section * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
    }

    /* Filter Buttons */
    .filter-section-ss {
        margin-bottom: 50px;
        border-bottom: 1px solid #e0e0e0;
        padding-bottom: 30px;
    }

    .filter-buttons-ss {
        display: flex;
        flex-wrap: wrap;
        gap: 12px;
    }

    .filter-btn-ss {
        padding: 12px 24px;
        border: 1px solid #d0d0d0;
        background-color: transparent;
        color: #666;
        font-size: 14px;
        font-weight: 500;
        cursor: pointer;
        transition: all 0.3s ease;
        border-radius: 2px;
        font-family: inherit;
    }

    .filter-btn-ss:hover {
        border-color: #333;
        color: #333;
    }

    .filter-btn-ss.active-ss {
        background-color: #1a1a1a;
        color: white;
        border-color: #1a1a1a;
    }

    /* Section Header */
    .section-header-ss {
        margin-bottom: 40px;
    }

    .section-subtitle-ss {
        font-size: 12px;
        letter-spacing: 2px;
        text-transform: uppercase;
        color: #888;
        margin-bottom: 10px;
        font-weight: 500;
    }

    .section-title-ss {
        font-size: 42px;
        font-weight: 700;
        color: #1a1a1a;
        margin-bottom: 10px;
        line-height: 1.2;
    }

    /* Cards Grid */
    .cards-grid-ss {
        display: grid;
        grid-template-columns: repeat(3, 1fr);
        gap: 30px;
    }

    .system-card-ss {
        background-color: white;
        border-radius: 4px;
        overflow: hidden;
        box-shadow: 0 2px 8px rgba(0,0,0,0.06);
        transition: all 0.3s ease;
        cursor: pointer;
    }

    .system-card-ss:hover {
        box-shadow: 0 12px 24px rgba(0,0,0,0.12);
        transform: translateY(-4px);
    }

    .system-card-ss.hidden {
        display: none !important;
    }

    .card-image-wrapper {
        width: 100%;
        height: 280px;
        overflow: hidden;
        position: relative;
    }

    .card-image-ss {
        width: 100%;
        height: 100%;
        object-fit: cover;
        transition: transform 0.5s ease;
    }

    .system-card-ss:hover .card-image-ss {
        transform: scale(1.08);
    }

    .card-content-ss {
        padding: 28px;
        background: white;
    }

    .card-title-ss {
        font-size: 20px;
        font-weight: 600;
        color: #1a1a1a;
        margin-bottom: 10px;
        line-height: 1.3;
    }

    .card-description-ss {
        font-size: 15px;
        color: #666;
        line-height: 1.6;
        margin-bottom: 20px;
    }

    .view-system-ss {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        font-size: 13px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: 1px;
        color: #1a1a1a;
        text-decoration: none;
        transition: gap 0.3s ease;
    }

    .view-system-ss:hover {
        gap: 12px;
    }

    .view-system-ss::after {
        content: '→';
        font-size: 16px;
    }

    /* Empty State */
    .no-products-ss {
        grid-column: 1 / -1;
        text-align: center;
        padding: 80px 20px;
        color: #666;
        font-size: 18px;
        display: none;
    }

    .no-products-ss.show {
        display: block;
    }

    /* Responsive */
    @media (max-width: 1024px) {
        .cards-grid-ss {
            grid-template-columns: repeat(2, 1fr);
        }
    }

    @media (max-width: 768px) {
        .systems-section {
            padding: 40px 15px;
        }
        
        .cards-grid-ss {
            grid-template-columns: 1fr;
            gap: 20px;
        }
        
        .section-title-ss {
            font-size: 28px;
        }
        
        .filter-buttons-ss {
            gap: 8px;
        }
        
        .filter-btn-ss {
            padding: 10px 16px;
            font-size: 12px;
        }
        
        .card-image-wrapper {
            height: 240px;
        }
    }
</style>

<div class="systems-section">
    <!-- Filter Buttons -->
    <div class="filter-section-ss">
        <div class="filter-buttons-ss">
            <button class="filter-btn-ss active-ss" data-filter="all">All Systems</button>
            
            {% for collection in collections %}
                {% if collection.products.size > 0 %}
                    <button class="filter-btn-ss" data-filter="{{ collection.handle }}">
                        {{ collection.title }}
                    </button>
                {% endif %}
            {% endfor %}
        </div>
    </div>

    <!-- Section Header -->
    <div class="section-header-ss">
        {% assign total_products = 0 %}
        {% for collection in collections %}
            {% assign total_products = total_products | plus: collection.products.size %}
        {% endfor %}
        <div class="section-subtitle-ss">{{ total_products }} Products Available</div>
        <h2 class="section-title-ss">Systems</h2>
    </div>
    <!-- Cards Grid -->
    <div class="cards-grid-ss" id="productsGrid">
        {% assign seen_products = "" %}
        
        {% for collection in collections %}
            {% for product in collection.products %}
                {% assign product_key = product.id | append: "-" %}
                
                {% unless seen_products contains product_key %}
                    {% assign seen_products = seen_products | append: product_key %}
                    
                    {% assign product_collections = "" %}
                    {% for col in product.collections %}
                        {% assign product_collections = product_collections | append: col.handle | append: "," %}
                    {% endfor %}
                    
                    <div class="system-card-ss" 
                         data-collections="{{ product_collections }}"
                         data-product-id="{{ product.id }}">
                        
                        <div class="card-image-wrapper">
                            {% if product.featured_image %}
                                <img src="{{ product.featured_image | img_url: '600x450', crop: 'center' }}" 
                                     alt="{{ product.title | escape }}" 
                                     class="card-image-ss"
                                     loading="lazy">
                            {% else %}
                                <div style="width:100%;height:100%;background:#e0e0e0;display:flex;align-items:center;justify-content:center;color:#999;">
                                    No Image
                                </div>
                            {% endif %}
                        </div>
                        
                        <div class="card-content-ss">
                            <h3 class="card-title-ss">{{ product.title }}</h3>
                            <p class="card-description-ss">
                                {% if product.description != blank %}
                                    {{ product.description | strip_html | truncate: 100 }}
                                {% else %}
                                    Premium quality {{ product.title | downcase }} for your architectural needs.
                                {% endif %}
                            </p>
                             {% render 'wishlist', product: card_product %}
                            <a href="{{ product.url }}" class="view-system-ss">View System</a>
                        </div>
                    </div>
                {% endunless %}
            {% endfor %}
        {% endfor %}
        
        <div class="no-products-ss" id="noProductsMsg">
            No products found in this collection.
        </div>
    </div>
</div>

<script>
(function() {
    'use strict';
    
    function initFilters() {
        const filterButtons = document.querySelectorAll('.filter-btn-ss');
        const productCards = document.querySelectorAll('.system-card-ss');
        const noProductsMsg = document.getElementById('noProductsMsg');
        
        if (!filterButtons.length || !productCards.length) return;
        
        filterButtons.forEach(function(btn) {
            btn.addEventListener('click', function() {
                // Update active state
                filterButtons.forEach(function(b) {
                    b.classList.remove('active-ss');
                });
                this.classList.add('active-ss');
                
                const filter = this.dataset.filter;
                let visibleCount = 0;
                
                productCards.forEach(function(card) {
                    const collections = card.dataset.collections || '';
                    
                    if (filter === 'all' || collections.includes(filter)) {
                        card.classList.remove('hidden');
                        visibleCount++;
                    } else {
                        card.classList.add('hidden');
                    }
                });
                
                // Show empty message if needed
                if (noProductsMsg) {
                    if (visibleCount === 0) {
                        noProductsMsg.classList.add('show');
                    } else {
                        noProductsMsg.classList.remove('show');
                    }
                }
            });
        });
    }
    
    // Run when DOM is ready
    if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', initFilters);
    } else {
        initFilters();
    }
})();
</script>

{% schema %}
{
    "name": "Product Cards with Filter",
    "settings": [
        {
            "type": "text",
            "id": "section_title",
            "label": "Section Title",
            "default": "Systems"
        },
        {
            "type": "text",
            "id": "all_button_text",
            "label": "All Button Text",
            "default": "All Systems"
        }
    ],
    "presets": [
        {
            "name": "Product Cards with Filter"
        }
    ]
}
{% endschema %}