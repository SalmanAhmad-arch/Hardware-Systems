      "settings": {
        "custom_liquid": "<div class=\"page-width\">\n  <h1>My Wishlist</h1>\n  <div id=\"wishlist-container\" class=\"wishlist-grid\"></div>\n</div>\n\n<style>\n.wishlist-grid {\n  display: grid;\n  grid-template-columns: repeat(3, 1fr);\n  gap: 20px;\n}\n\n.wishlist-card {\n  border: 1px solid #eee;\n  padding: 15px;\n  text-align: center;\n  transition: 0.3s;\n}\n\n.wishlist-card:hover {\n  box-shadow: 0 5px 15px rgba(0,0,0,0.1);\n}\n\n.wishlist-card img {\n  width: 100%;\n  height: 200px;\n  object-fit: cover;\n}\n\n.empty-wishlist {\n  text-align: center;\n  font-size: 18px;\n  padding: 40px 0;\n}\n</style>\n\n<script>\ndocument.addEventListener('DOMContentLoaded', async () => {\n  const container = document.getElementById('wishlist-container');\n\n  let wishlist = JSON.parse(localStorage.getItem('wishlist')) || [];\n\n  // ✅ Remove duplicates\n  wishlist = wishlist.filter((item, index, self) =>\n    index === self.findIndex(t => t.handle === item.handle)\n  );\n\n  if (wishlist.length === 0) {\n    container.innerHTML = `<div class=\"empty-wishlist\">Your wishlist is empty 💔</div>`;\n    return;\n  }\n\n  let html = \"\";\n\n  for (let item of wishlist) {\n    try {\n      let response = await fetch(`/products/${item.handle}.js`);\n\n      if (!response.ok) throw new Error(\"Product not found\");\n\n      let product = await response.json();\n\n      let image = product.images.length > 0 \n        ? product.images[0] \n        : \"https://via.placeholder.com/300\";\n\n      html += `\n        <div class=\"wishlist-card\">\n          <img src=\"${image}\" alt=\"${product.title}\" />\n          <h3>${product.title}</h3>\n          <p>${(product.price / 100).toFixed(2)} PKR</p>\n          <a href=\"/products/${product.handle}\">View Product</a>\n        </div>\n      `;\n\n    } catch (error) {\n      console.log(\"Error loading product:\", item.handle);\n    }\n  }\n\n  container.innerHTML = html;\n});\n</script>",
        "color_scheme": "",
