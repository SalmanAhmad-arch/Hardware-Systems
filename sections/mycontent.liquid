<style>
body {
    margin: 0;
    padding: 0;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}
.page-width { max-width: 100% !important;
   padding: 0 !important;
    margin:0; }

.header {
    position: relative;
    height: 110vh;
    width: 100vw;
    background-image: url("https://cdn.shopify.com/s/files/1/1021/8078/2161/files/photo-1600210492486-724fe5c67fb0.jpg?v=1773731100");
    background-size: cover;
    background-position: center;
    display: flex;
    align-items: center;
    justify-content: center;
}

/* 🔥 STRONG OVERLAY */
.header::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
    z-index: 1;
}

/* CONTENT */
.content {
    position: relative;
    z-index: 2;
    text-align: center;
    color: white;
    max-width: 900px;
}

/* TOP SMALL TEXT */
.para1 {
    font-size: 12px;
    letter-spacing: 4px;
    text-transform: uppercase;
    margin-bottom: 15px;
    opacity: 0.8;
}

/* 🔥 MAIN HEADING (exact feel) */
h1 {
    font-weight: 800;
    margin: 10px 0 20px;
    font-size: 72px;
    color:white;
    line-height: 1.1;
}

/* DESCRIPTION */
.para2 {
    font-size: 18px;
    margin-bottom: 40px;
    line-height: 1.7;
    opacity: 0.9;
}
.butn1 {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    padding: 18px 55px;
    font-size: 12px;
    font-weight: 600;
    letter-spacing: 2px;
    text-transform: uppercase;
    background: #111;
    color: #fff;
    border: none;
    cursor: pointer;
    transition: all 0.3s ease;
}

/* arrow styling */
.butn1 span {
    font-size: 16px;
    transition: transform 0.3s ease;
}

/* hover */
.butn1:hover {
    background: #000;
}

.butn1:hover span {
    transform: translateY(3px);
}

/* RESPONSIVE */
@media (max-width: 768px) {

    .header {
        height: 85vh;
        padding: 30px 15px;
    }

    h1 {
        font-size: 34px;
    }

    .para2 {
        font-size: 15px;
    }

    .butn1 {
        padding: 14px 26px;
        font-size: 12px;
    }
}

</style>

 <div class="header page-width">
    <div class="content">
        {% if section.settings.small_heading != blank %}
            <p class="para1">{{ section.settings.small_heading }}</p>
        {% endif %}
        {% if section.settings.main_heading != blank %}
            <h1>{{ section.settings.main_heading }}</h1>
        {% endif %}
        {% if section.settings.description != blank %}
            <p class="para2">{{ section.settings.description }}</p>
        {% endif %}
            <button class="butn1" id="exploreBtn">Explore Categories ↓</button>
      
    </div>
</div>
<script>
document.addEventListener('DOMContentLoaded', function() {
    // Button ko select karo
    const exploreBtn = document.getElementById('exploreBtn');
    
    // Agar button exist karta hai
    if (exploreBtn) {
        exploreBtn.addEventListener('click', function(e) {
            e.preventDefault(); // Default action roko
            
            // Categories section dhoondo
            const productsSection = document.querySelector('.categories');
            
            if (productsSection) {
                // Smooth scroll karo
                productsSection.scrollIntoView({
                    behavior: 'smooth',
                    block: 'start'
                });
            } else {
                console.log('Categories section not found!');
            }
        })
    }
});
</script>
{% schema %}
{
  "name": "Custom Hero Section",
  "settings": [
    {
      "type": "text",
      "id": "small_heading",
      "label": "Small Heading",
      "default": "OPUS HARDWARE"
    },
    {
      "type": "text",
      "id": "main_heading",
      "label": "Main Heading",
      "default": "Hardware Systems"
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "Precision-engineered architectural hardware systems for glass, doors, and facades. Designed for professionals who demand excellence."
    },
    {
  "type": "color",
  "id": "text_color",
  "label": "Main Text Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "subtext_color",
  "label": "Sub Text Color",
  "default": "#ffffffcc"
},
{
  "type": "range",
  "id": "heading_size",
  "label": "Heading Font Size",
  "min": 30,
  "max": 100,
  "step": 2,
  "default": 72
},
{
  "type": "color",
  "id": "button_bg",
  "label": "Button Background",
  "default": "#1e1111"
},
{
  "type": "color",
  "id": "button_text_color",
  "label": "Button Text Color",
  "default": "#ffffff"
},
{
  "type": "color",
  "id": "button_border",
  "label": "Button Border Color",
  "default": "#ffffff"
}
  ],
  "blocks": [],
  "presets": [
    {
      "name": "Custom Hero Section"
    }
  ]
}
{% endschema %}
